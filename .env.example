# Copy to .env and fill in. .env is gitignored.

# Which backend to use: groq (cloud) or ollama (local).
PROVIDER=ollama

# --- Groq (PROVIDER=groq) ---
# Free API key, no credit card: https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# --- Ollama (PROVIDER=ollama) ---
# No key. Needs Ollama running locally (https://ollama.com) and a model pulled:
#   ollama pull qwen2.5-coder:7b-instruct

# Optional: override the model for whichever provider is selected.
# Groq default:   llama-3.3-70b-versatile
# Ollama default: qwen2.5-coder:7b-instruct
# MODEL=
